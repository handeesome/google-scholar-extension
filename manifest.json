{
  "manifest_version": 3,
  "name": "Google Scholar Tracker",
  "version": "1.0",
  "description": "Tracks which academic papers you've visited on Google Scholar.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "identity",
    "system.display"
  ],
  "host_permissions": [
    "https://scholar.google.com/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://scholar.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": { "default_popup": "popup.html" },
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["<all_urls>"]
    }
  ],
  "key": ""
}
